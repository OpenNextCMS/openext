  "installation": {
    "title": "Project Installation",
    "description": "Step-by-step guide to set up and run OpenNext CMS on your local machine",
    "requirements": [
      "Node.js (v18 or higher) installed",
      "NPM (comes with Node.js)",
      "MongoDB (local or cloud instance)",
      "Code editor (VS Code recommended)"
    ],
    "steps": [
      {
        "step": 1,
        "title": "Download Project",
        "content": "Download the project files from [demo@doc.com](mailto:demo@doc.com)"
      },
      {
        "step": 2,
        "title": "Unzip Files",
        "content": "Extract the downloaded zip file to your preferred directory"
      },
      {
        "step": 3,
        "title": "Open Terminal",
        "content": "Navigate to the project directory using your terminal or command prompt"
      },
      {
        "step": 4,
        "title": "Install Dependencies",
        "content": "Run the following command to install all required packages:\n```bash\nnpm install\n```"
      },
      {
        "step": 5,
        "title": "Run Development Server",
        "content": "Start the development server with:\n```bash\nnpm run dev\n```"
      },
      {
        "step": 6,
        "title": "Access Application",
        "content": "Open your browser and visit:\n```\nhttp://localhost:3000\n```"
      },
      {
        "step": 7,
        "title": "Initial Setup",
        "content": "Follow the on-screen instructions to complete the initial setup wizard"
      }
    ],
    "troubleshooting": [
      {
        "issue": "Port 3000 already in use",
        "solution": "Either stop the other process using port 3000 or change the port in `.env`:\n```env\nPORT=3001\n```"
      },
      {
        "issue": "MongoDB connection failed",
        "solution": "Ensure MongoDB is running and the connection string is correct"
      },
      {
        "issue": "NPM install errors",
        "solution": "Try deleting `node_modules` and `package-lock.json`, then run:\n```bash\nnpm cache clean --force\nnpm install\n```"
      }
    ]
  },
  "overview": {
    "title": "OpenNext CMS Documentation",
    "description": "OpenNext is a modern, self-hosted content management system built with Next.js, designed to provide a WordPress-like experience with cutting-edge web technologies. This open-source project allows users to easily install and run their own CMS on their servers, featuring a powerful drag-and-drop editor for seamless website creation and management. Built with scalability and developer experience in mind, OpenNext combines the flexibility of WordPress with the performance of modern web frameworks.",
    "objectives": [
      "Provide a WordPress-like CMS experience with modern web technologies",
      "Enable one-click installation and setup process",
      "Offer a powerful drag-and-drop editor for non-technical users",
      "Support multi-user roles and permissions system",
      "Provide secure user authentication with JWT and bcrypt",
      "Enable dynamic content management with MongoDB",
      "Support custom themes and plugins architecture",
      "Offer RESTful API for headless CMS functionality",
      "Provide real-time content preview during editing",
      "Support multi-language content management",
      "Enable easy media management and file uploads",
      "Provide SEO optimization tools out of the box",
      "Support responsive design for all devices",
      "Offer scalable architecture for growing needs",
      "Provide comprehensive documentation and developer tools"
    ]
  },
  "features": [
    {
      "title": "Authentication System",
      "content": "Secure user registration and login flow with MongoDB storage and JWT authentication, including password recovery and role-based access control"
    },
    {
      "title": "Dynamic Site Creation",
      "content": "On-the-fly database configuration and site initialization during user onboarding with automatic setup wizard"
    },
    {
      "title": "User Management",
      "content": "Comprehensive admin panel with user role management, profile customization, and activity tracking"
    },
    {
      "title": "Content Management",
      "content": "Advanced content editor with real-time preview, version control, and scheduled publishing"
    },
    {
      "title": "Media Library",
      "content": "Built-in media manager with support for images, videos, and documents, including drag-and-drop uploads"
    },
    {
      "title": "SEO Optimization",
      "content": "Built-in SEO tools including meta tags management, sitemap generation, and URL customization"
    },
    {
      "title": "Multi-language Support",
      "content": "Native support for multi-language content with automatic language detection and translation management"
    },
    {
      "title": "Custom Themes",
      "content": "Flexible theme system supporting custom designs and easy theme switching"
    },
    {
      "title": "API Integration",
      "content": "RESTful API for headless CMS functionality and third-party integrations"
    },
    {
      "title": "Real-time Analytics",
      "content": "Built-in analytics dashboard with real-time visitor tracking and performance metrics"
    },
    {
      "title": "Backup & Restore",
      "content": "Automated backup system with one-click restore functionality"
    },
    {
      "title": "Responsive Design",
      "content": "Fully responsive interface that works seamlessly across all devices"
    },
    {
      "title": "Plugin System",
      "content": "Extensible architecture supporting custom plugins and integrations"
    },
    {
      "title": "E-commerce Ready",
      "content": "Built-in e-commerce features including product management and payment gateway integration"
    },
    {
      "title": "Security Features",
      "content": "Advanced security measures including two-factor authentication, brute force protection, and activity monitoring"
    }
  ],
