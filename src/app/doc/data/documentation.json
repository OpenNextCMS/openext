      "title": "Authentication APIs",
      "color": "text-blue-600",
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/auth/setup-databases",
          "description": "Sets up separate databases for users and pages",
          "apiNumber": 1,
          "color": "blue",
          "request": {
            "userDbName": "DB-User01",
            "pageDbName": "DB-Page01",
            "mongodbCredentials": {
              "username": "yourUsername",
              "password": "yourPassword",
              "host": "yourMongoHost",
              "cluster": "Cluster0"
            }
          },
          "response": {
            "success": true,
            "message": "Operation successful",
            "data": "Databases setup successful...",
            "status": 200
          }
        },
